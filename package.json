    "@tailwindcss/vite": "^4.2.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "~25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.4.0",
